
{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Interesse de consultoria capturado via site.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "business": { "type": "string" },
        "niche": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "Dossiê técnico ou artigo estratégico para a rede Sapient.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "featuredImageUri": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "publishedDate": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "slug", "content"]
    },
    "SalesCandidate": {
      "title": "Sales Candidate",
      "description": "Candidato a vendedor avaliado via ficha técnica e testes de locução.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "instagram": { "type": "string" },
        "linkedin": { "type": "string" },
        "cityState": { "type": "string" },
        "currentOccupation": { "type": "string" },
        "experience": { "type": "string" },
        "consentAccepted": { "type": "boolean" },
        "consentTimestamp": { "type": "string", "format": "date-time" },
        "ansAds": { "type": "string" },
        "ansSites": { "type": "string" },
        "ansChat": { "type": "string" },
        "ansSocial": { "type": "string" },
        "audioObjeçãoAds": { "type": "string" },
        "audioCirurgiao": { "type": "string" },
        "pitchAudioUri": { "type": "string", "description": "URI de dados Base64 do áudio do pitch final." },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PENDENTE_AVALIACAO_HUMANA", "APROVADO", "REPROVADO"] }
      },
      "required": ["name", "email", "phone", "consentAccepted"]
    }
  },
  "auth": {
    "providers": ["google", "anonymous"]
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Leads de consultoria capturados."
    },
    "/blogPosts_public/{postId}": {
      "schema": "BlogPost",
      "description": "Artigos estratégicos abertos ao público."
    },
    "/sales_candidates/{candidateId}": {
      "schema": "SalesCandidate",
      "description": "Fichas completas de recrutamento comercial."
    }
  }
}
