
{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Interesse de consultoria capturado via site.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "business": { "type": "string" },
        "niche": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Leads de consultoria capturados."
    }
  }
}
