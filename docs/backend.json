
{
  "entities": {
    "BlogPost": {
      "title": "BlogPost",
      "description": "Representa um post do blog da Sapient Studio.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "featuredImageUri": { "type": "string", "format": "uri" },
        "publishedDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["DRAFT", "PUBLISHED"] },
        "isPremium": { "type": "boolean" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "slug", "content", "status", "authorId"]
    },
    "Author": {
      "title": "Author",
      "description": "Autor de posts do blog.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "profilePictureUri": { "type": "string", "format": "uri" }
      },
      "required": ["name", "profilePictureUri"]
    }
  },
  "auth": {
    "providers": ["google.com", "anonymous"]
  },
  "firestore": {
    "/blogPosts_public/{blogPostId}": {
      "schema": "BlogPost",
      "description": "Posts públicos visíveis a todos."
    },
    "/blogPosts_premium/{blogPostId}": {
      "schema": "BlogPost",
      "description": "Posts exclusivos para usuários premium."
    },
    "/admin_blogPosts_drafts/{blogPostId}": {
      "schema": "BlogPost",
      "description": "Rascunhos visíveis apenas para admins."
    },
    "/roles_admin/{userId}": {
      "schema": "object",
      "description": "Identificação de administradores."
    }
  }
}
