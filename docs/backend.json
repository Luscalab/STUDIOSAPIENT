
{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Interesse de consultoria capturado via site.",
      "type": "object",
      "properties": {
        "conversation": { "type": "string" },
        "source": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "CommercialLead": {
      "title": "CommercialLead",
      "description": "Lead de prospecção estratégica com diagnóstico para os consultores.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "contactName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "category": { "type": "string" },
        "googleRating": { "type": "number" },
        "region": { "type": "string" },
        "address": { "type": "string" },
        "website": { "type": "string" },
        "status": { "type": "string", "enum": ["NOVO", "EM_CONTATO", "NEGOCIACAO", "FECHADO", "PERDIDO"] },
        "bottlenecks": { "type": "string" },
        "suggestedServices": { "type": "array", "items": { "type": "string" } },
        "salesScript": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SalesProfile": {
      "title": "SalesProfile",
      "description": "Perfil persistente do consultor de vendas.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "instagram": { "type": "string" },
        "cityState": { "type": "string" },
        "currentOccupation": { "type": "string" },
        "experience": { "type": "string" },
        "photoUri": { "type": "string" },
        "resumeUri": { "type": "string" },
        "consentAccepted": { "type": "boolean" },
        "consentTimestamp": { "type": "string", "format": "date-time" },
        "leadsEnabled": { "type": "boolean", "default": false }
      }
    },
    "SalesCandidate": {
      "title": "SalesCandidate",
      "description": "Candidato a vendedor avaliado via ficha técnica.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "instagram": { "type": "string" },
        "cityState": { "type": "string" },
        "currentOccupation": { "type": "string" },
        "experience": { "type": "string" },
        "photoUri": { "type": "string" },
        "resumeUri": { "type": "string" },
        "ansAds": { "type": "string" },
        "ansSites": { "type": "string" },
        "ansDesign": { "type": "string" },
        "ansChat": { "type": "string" },
        "ansSocial": { "type": "string" },
        "ansNarrativa": { "type": "string" },
        "ansNichos": { "type": "string" },
        "ansPreco": { "type": "string" },
        "audioObjeçãoAds": { "type": "string" },
        "pitchAudioUri": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PENDENTE_AVALIACAO_HUMANA", "APROVADO", "REPROVADO"] }
      },
      "required": ["name", "email", "phone"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Leads de consultoria capturados via chat inteligente."
    },
    "/commercial_leads/{leadId}": {
      "schema": "CommercialLead",
      "description": "Base de dados de prospecção estratégica."
    },
    "/sales_profiles/{userId}": {
      "schema": "SalesProfile",
      "description": "Perfis persistentes dos consultores logados."
    },
    "/sales_candidates/{candidateId}": {
      "schema": "SalesCandidate",
      "description": "Dossiês completos de recrutamento comercial."
    }
  }
}
