
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bloqueio total por padrão
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Auxiliar para verificar se o usuário é o administrador mestre
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "contato@studiosapient.com.br" || 
        request.auth.token.email == "lucassouza.sou@gmail.com"
      );
    }

    // Leads: permite apenas criação pública. Leitura e exclusão restritas ao admin.
    match /leads/{leadId} {
      allow create: if true;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // Perfis de Vendas: Usuário gerencia o seu próprio, Admin lê tudo
    match /sales_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Candidatos a Vendas (Dossiês): criação pública para o processo, Admin gerencia.
    match /sales_candidates/{candidateId} {
      allow create: if request.auth != null;
      allow read, delete, update: if isAdmin();
    }
  }
}
