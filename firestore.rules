
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bloqueio padrão para segurança máxima
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Auxiliar para verificar se o usuário é o administrador mestre
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "contato@studiosapient.com.br";
    }

    // Leads: qualquer um pode enviar interesse, mas apenas o admin pode ler/apagar
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Status de Usuário Premium: o próprio usuário pode ler seu status (futuro uso)
    match /premium_users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
